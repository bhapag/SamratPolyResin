---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import ProductCard from '../components/ProductCard.astro';
import { products, CATEGORIES } from '../data/products.js';
import { site } from '../data/site.js';
import qcLaboratory from '../assets/quality/qc-laboratory.jpg';
import productionInfrastructure from '../assets/facility/production-infrastructure.jpg';

const waLink = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent("Hi, I'd like to enquire about your resins.")}`;
const featured = products.slice(0, 6);
const [whyWord, chooseWord, samratWord, polyWord, resinsWord] = `Why choose ${site.name}`.split(' ');

// site.statesServed mixes domestic states and "Export <country>" entries in
// one list (used as-is, unfiltered, by the separate "Industries We Serve"
// section further down this page). The Pan India Supply / Export Markets
// cards need those two groups split apart, so we derive both views here
// rather than touching the shared site.js array or that other section.
const domesticStates = site.statesServed.filter((s) => !s.startsWith('Export '));
const exportMarkets = site.statesServed.filter((s) => s.startsWith('Export ')).map((s) => s.replace('Export ', ''));
---
<Base>
  <!-- ================= HERO ================= -->
  <section class="hero">
    <div class="hero-grid-lines" aria-hidden="true"></div>
    <div class="wrap hero-inner">
      <p class="eyebrow">Trusted industrial resin manufacturer</p>
      <h1 class="hero-title">
        Engineered for<br/>
        <span class="hl">quality</span>.<br/>
        Built for<br/>
        <span class="hl">performance</span>.
      </h1>
      <p class="hero-sub">
        {site.name} manufactures premium GP Polyester, Gel Coat, Fire Retardant,
        Epoxy and Specialty Resin systems for FRP manufacturers and industrial
        applications across India.
      </p>
      <div class="hero-trust">
        <span class="hero-trust-item">ISO 9001:2015 Certified</span>
        <span class="hero-trust-item">Manufacturer Since {site.established}</span>
        <span class="hero-trust-item">GST Verified</span>
        <span class="hero-trust-item">Pan-India Supply</span>
      </div>
      <div class="hero-cta">
        <a href="/products/" class="btn btn-solid">Explore products</a>
        <a href={waLink} class="btn btn-wa" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.2s-.8.9-.9 1.1c-.2.2-.3.2-.6.1-.3-.2-1.2-.5-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5 0-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.5c-.2 0-.5 0-.7.3-.2.3-.9.9-.9 2.2s1 2.5 1.1 2.7c.1.2 1.9 3 4.7 4.2 2.8 1.2 2.8.8 3.3.8.5 0 1.7-.7 1.9-1.4.2-.6.2-1.2.2-1.4-.1-.1-.3-.2-.6-.3z"/></svg>
          Request quotation
        </a>
      </div>
    </div>
  </section>

  <!-- ================= CATEGORY TEASER ================= -->
  <section class="section cats">
    <div class="wrap cats-grid">
      <div class="cats-main">
        <div class="section-head">
          <p class="eyebrow">Product range</p>
          <h2>What we manufacture</h2>
        </div>
        <div class="cat-grid">
          {CATEGORIES.map(cat => (
            <a href={`/products/#${cat.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}`} class="cat-tile">
              <span class="cat-tile-name">{cat}</span>
              <span class="cat-tile-count">{products.filter(p => p.category === cat).length} grades</span>
            </a>
          ))}
        </div>
      </div>
      <div class="cats-video">
        <video data-src="/home-video.mp4" muted loop playsinline preload="none" poster="/logo.jpg" disablepictureinpicture disableremoteplayback></video>
      </div>
    </div>
  </section>

  <!-- ================= FEATURED PRODUCTS ================= -->
  <section class="section featured">
    <div class="wrap">
      <div class="section-head featured-head">
        <div>
          <p class="eyebrow">A few of our grades</p>
          <h2>Popular products</h2>
        </div>
        <a href="/products/" class="btn">See all products →</a>
      </div>
      <div class="grid">
        {featured.map(p => <ProductCard product={p} />)}
      </div>
    </div>
  </section>

  <!-- ================= WHY CHOOSE US ================= -->
  <section class="section why-us">
    <div class="wrap">
      <div class="section-head">
        <p class="eyebrow">Why choose us</p>
        <h2><span class="why-heading-gold">{whyWord}</span> <span class="why-heading-white">{chooseWord}</span> <span class="why-heading-red">{samratWord}</span> <span class="why-heading-poly">{polyWord}</span> <span class="why-heading-blue">{resinsWord}</span></h2>
      </div>
      <div class="why-grid">
        <div class="why-card why-card-cert">
          <div class="why-head">
            <span class="why-check" aria-hidden="true">✓</span>
            <h3 class="why-title">ISO 9001:2015 Certified</h3>
          </div>
          <p class="why-desc">Our quality management system is certified to ISO 9001:2015 standards, ensuring consistent manufacturing and reliable production processes.</p>
          <div class="why-cert-row">
            <a href="/certificates/iso-9001-2015-certificate.png" target="_blank" rel="noopener" class="why-cert-thumb" aria-label="View full ISO 9001:2015 certificate">
              <img src="/certificates/iso-9001-2015-certificate.png" alt="ISO 9001:2015 Certificate of Registration — Samrat Poly Resins" width="1086" height="1448" loading="lazy" />
            </a>
            <a href="/certificates/iso-9001-2015-certificate.png" target="_blank" rel="noopener" class="btn why-cert-btn">View certificate</a>
          </div>
        </div>
        <div class="why-card why-card-timeline">
          <div class="why-head">
            <span class="why-check" aria-hidden="true">✓</span>
            <h3 class="why-title">{new Date().getFullYear() - Number(site.established)}+ Years Manufacturing Experience</h3>
          </div>
          <p class="why-desc">Trusted by industrial buyers since {site.established}, supplying premium polyester resin solutions across multiple industries.</p>
          <div class="why-timeline" aria-hidden="true">
            <span class="why-timeline-year">{site.established}</span>
            <span class="why-timeline-bar"></span>
            <span class="why-timeline-year">{new Date().getFullYear()}</span>
          </div>
          <p class="why-timeline-label">{new Date().getFullYear() - Number(site.established)}+ Years of Manufacturing Excellence</p>
        </div>
        <div class="why-card">
          <div class="why-head">
            <span class="why-check" aria-hidden="true">✓</span>
            <h3 class="why-title">GST Registered Manufacturer</h3>
          </div>
          <p class="why-desc">Registered under India's Goods and Services Tax (GST), ensuring transparent and compliant business operations.</p>
          <div class="why-gst">
            <div class="why-gst-rule" aria-hidden="true"></div>
            <span class="why-gst-label">GSTIN</span>
            <p class="why-gst-number">{site.gst}</p>
            <button type="button" id="gstCopyBtn" class="btn why-gst-copy" data-gstin={site.gst}>
              <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="M8 7V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-2v2a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2h2zm2 0h4a2 2 0 0 1 2 2v4h2V5h-8v2zM6 9v8h8V9H6z"/></svg>
              <span class="why-gst-copy-text" aria-live="polite">Copy GSTIN</span>
            </button>
            <p class="why-gst-caption">Verify our GST registration using this GSTIN.</p>
            <div class="why-gst-rule" aria-hidden="true"></div>
          </div>
        </div>
        <div class="why-card">
          <div class="why-head">
            <span class="why-check" aria-hidden="true">✓</span>
            <h3 class="why-title">Bulk Orders Accepted</h3>
          </div>
          <p class="why-desc">Manufacturing capacity designed to efficiently fulfill large-volume industrial requirements.</p>
          <div class="why-bulk">
            <div class="why-bulk-rule" aria-hidden="true"></div>
            <div class="why-bulk-row">
              <span class="why-bulk-value">{site.packagingRange}</span>
              <span class="why-bulk-label">Standard Drum Packaging</span>
            </div>
            <div class="why-bulk-row">
              <span class="why-bulk-value">Flexible</span>
              <span class="why-bulk-label">Order Quantities</span>
            </div>
            <div class="why-bulk-rule" aria-hidden="true"></div>
            <svg class="why-drums-svg" viewBox="0 0 200 56" aria-hidden="true">
              <g>
                <rect x="8" y="4" width="48" height="48" rx="5" class="why-drum-body" />
                <rect x="8" y="26" width="48" height="7" class="why-drum-band" />
              </g>
              <g>
                <rect x="76" y="4" width="48" height="48" rx="5" class="why-drum-body" />
                <rect x="76" y="26" width="48" height="7" class="why-drum-band" />
              </g>
              <g>
                <rect x="144" y="4" width="48" height="48" rx="5" class="why-drum-body" />
                <rect x="144" y="26" width="48" height="7" class="why-drum-band" />
              </g>
            </svg>
          </div>
        </div>
      </div>

      <div class="why-grid why-logistics-grid">
        <div class="why-card">
          <div class="why-head">
            <span class="why-check" aria-hidden="true">✓</span>
            <h3 class="why-title">Pan India Supply</h3>
          </div>
          <p class="why-desc">Reliable logistics network serving customers across India with timely delivery and bulk shipment capability.</p>
          <div class="why-india">
            <svg class="why-india-map" viewBox="-26 -26 360 364" aria-hidden="true">
              <path class="why-india-land" d="M 103.17 4 L 114.2 16.95 L 113.16 25.97 L 117.24 31.62 L 116.91 37.26 L 109.54 35.78 L 112.42 47.96 L 122.5 54.96 L 136.77 62.68 L 130.26 67.69 L 126.27 78.03 L 136.22 82.21 L 145.89 87.63 L 159.28 93.83 L 173.35 95.26 L 179.27 100.88 L 187.2 101.94 L 199.55 104.51 L 208.1 104.33 L 209.28 99.95 L 207.93 92.93 L 208.72 88.17 L 214.98 85.85 L 215.84 94.55 L 216.06 96.77 L 225.39 100.96 L 231.85 99.23 L 240.51 99.97 L 248.89 99.65 L 249.61 92.86 L 245.43 89.33 L 253.71 87.95 L 263.05 79.73 L 274.88 72.69 L 283.49 75.41 L 290.81 70.76 L 295.62 77.63 L 292.16 82.27 L 303.23 83.92 L 304 88.11 L 300.4 90.13 L 301.24 96.93 L 293.91 94.94 L 280.62 102.57 L 280.93 108.9 L 275.27 118.16 L 274.75 123.55 L 270.17 132.66 L 262.15 130.14 L 261.75 141.58 L 259.43 145.34 L 260.51 150.03 L 255.45 152.65 L 250.04 135.13 L 247.21 135.16 L 245.53 142.22 L 239.91 136.5 L 243.08 130.21 L 247.67 129.57 L 252.41 120.22 L 246.49 118.33 L 236.97 118.49 L 227.2 116.98 L 226.29 109.3 L 221.39 108.75 L 213.26 103.98 L 209.64 111.47 L 217.05 117.32 L 210.63 121.44 L 208.35 125.47 L 214.67 128.43 L 212.92 135.09 L 216.48 143.4 L 218.08 152.49 L 216.61 156.53 L 209.62 156.39 L 196.97 158.68 L 197.56 167 L 192.08 173.53 L 177.31 180.97 L 165.82 193.97 L 158.1 200.94 L 147.87 208.18 L 147.86 213.26 L 142.74 215.98 L 133.49 219.94 L 128.7 220.52 L 125.62 228.95 L 127.76 243.33 L 128.3 252.49 L 123.95 262.99 L 123.91 281.76 L 118.6 282.3 L 113.92 290.73 L 117.05 294.37 L 107.69 297.5 L 104.23 305.02 L 100.11 308.19 L 90.39 297.87 L 85.64 282.4 L 81.7 271.25 L 78.11 266.03 L 72.65 255.41 L 70.11 241.59 L 68.33 234.69 L 58.99 219.51 L 54.74 198.1 L 51.67 183.96 L 51.71 170.57 L 49.72 160.23 L 34.78 166.84 L 27.55 165.52 L 14.14 152.12 L 19.07 148.13 L 16.04 143.79 L 4 134.41 L 10.84 127.04 L 33.43 127.07 L 31.39 117.58 L 25.62 111.98 L 24.45 103.47 L 17.73 98.51 L 29.04 86.93 L 40.96 87.77 L 51.7 76.18 L 58.14 64.97 L 68.1 53.88 L 67.94 46.01 L 76.7 39.61 L 68.41 34.16 L 64.85 26.68 L 61.21 17 L 66.24 12.23 L 81.81 14.93 L 93.25 13.29 L 103.17 4 Z" />
              <!-- Domestic supply markers (approximate positions, illustrative not geographic) -->
              <circle class="why-india-dot" cx="93.85" cy="45.81" r="4.5" />
              <circle class="why-india-dot" cx="82.87" cy="54.76" r="4.5" />
              <circle class="why-india-dot" cx="94.47" cy="68.13" r="4.5" />
              <circle class="why-india-dot" cx="96.73" cy="80.07" r="4" />
              <circle class="why-india-dot" cx="150" cy="108" r="4" />
              <circle class="why-india-dot" cx="156" cy="129" r="4" />
              <circle class="why-india-dot" cx="180" cy="139" r="4" />
              <circle class="why-india-dot" cx="169" cy="163" r="4" />
              <circle class="why-india-dot" cx="230" cy="100" r="4" />
              <circle class="why-india-dot" cx="132.04" cy="213.77" r="4.5" />
            </svg>
            <p class="why-india-caption">
              Currently supplying customers across:<br />
              {domesticStates.join(' • ')}
            </p>
          </div>
        </div>
        <div class="why-card">
          <div class="why-head">
            <span class="why-check" aria-hidden="true">✓</span>
            <h3 class="why-title">Export Markets</h3>
          </div>
          <p class="why-desc">Supplying premium polyester resin products to neighbouring international markets through reliable export logistics.</p>
          <div class="why-india">
            <svg class="why-india-map why-export-map" viewBox="1168 -512 400 264" aria-hidden="true">
              <!-- Real, simplified country outlines (projected from public-domain
                   Natural-Earth-derived boundary data — johan/world.geo.json —
                   not hand-drawn), cropped to eastern/northern India, Nepal and
                   Bangladesh. Equirectangular projection, single shared scale so
                   relative size and position stay geographically accurate. -->
              <path class="why-india-land" d="M 1245.4,-567.9 L 1262.6,-549.2 L 1261,-536.1 L 1267.3,-527.9 L 1266.8,-519.7 L 1255.3,-521.9 L 1259.8,-504.3 L 1297.8,-482.9 L 1287.6,-475.7 L 1281.4,-460.7 L 1332.9,-437.8 L 1354.8,-435.8 L 1364,-427.6 L 1409,-422.6 L 1409.9,-446 L 1419.7,-449.4 L 1421.4,-433.6 L 1435.9,-427.5 L 1472.5,-429.4 L 1473.7,-439.2 L 1467.1,-444.3 L 1480,-446.4 L 1513.1,-468.4 L 1526.5,-464.5 L 1537.9,-471.2 L 1545.4,-461.3 L 1540,-454.6 L 1557.2,-452.2 L 1558.4,-446.1 L 1552.8,-443.2 L 1554.1,-433.3 L 1542.7,-436.2 L 1522,-425.2 L 1522.5,-416 L 1505.7,-381.6 L 1493.2,-385.3 L 1490.7,-356.5 L 1482.8,-352.7 L 1474.3,-378 L 1469.9,-378 L 1467.3,-367.8 L 1458.5,-376.1 L 1478,-399.6 L 1438.7,-404.3 L 1437.3,-415.4 L 1417,-423.1 L 1411.4,-412.3 L 1422.9,-403.8 L 1409.4,-392 L 1419.2,-387.7 L 1422.2,-347 L 1391.6,-343.9 L 1392.5,-331.9 L 1384,-322.4 L 1361,-311.7 L 1315.1,-272.3 L 1315.1,-264.9 L 1285.2,-254.4 L 1280.4,-242.2 L 1284.6,-208.1 L 1277.8,-192.9 L 1277.7,-165.7 L 1269.4,-164.9 L 1262.2,-152.7 L 1267,-147.5 L 1252.4,-142.9 L 1240.6,-127.4 L 1225.5,-142.4 L 1197.8,-203.9 L 1191.1,-233.9 L 1176.5,-255.9 L 1162.1,-341.7 L 1138.8,-332.1 L 1127.5,-334 L 1106.6,-353.4 L 1114.3,-359.2 L 1109.6,-365.5 L 1090.8,-379.1 L 1101.5,-389.7 L 1136.7,-389.7 L 1122.7,-423.9 L 1112.2,-431.1 L 1129.9,-447.8 L 1148.4,-446.6 L 1190.7,-495.7 L 1190.5,-507.1 L 1204.1,-516.3 L 1191.2,-524.2 L 1180,-549.1 L 1187.8,-556 L 1229.9,-554.5 L 1245.4,-567.9 Z" />
              <path class="why-export-neighbour" d="M 1409.9,-446 L 1408.7,-439.1 L 1410.8,-429 L 1409,-422.6 L 1395.6,-422.4 L 1364,-427.6 L 1354.8,-435.8 L 1332.9,-437.8 L 1281.4,-460.7 L 1287.6,-475.7 L 1304.4,-486.8 L 1317.2,-481.8 L 1333.4,-471.4 L 1342.4,-469.1 L 1347.8,-461.4 L 1360.2,-458.3 L 1373.2,-451.3 L 1391.3,-447.6 L 1409.9,-446 Z" />
              <path class="why-export-neighbour" d="M 1482.8,-352.7 L 1482.4,-341.2 L 1476.9,-343.6 L 1477.9,-330.7 L 1473.3,-339.1 L 1472.4,-347.2 L 1469.4,-354.9 L 1462.7,-364.2 L 1447.9,-364.9 L 1449.4,-358.3 L 1444.4,-349.4 L 1437.6,-352.6 L 1435.2,-349.7 L 1424.5,-352.9 L 1422,-366.1 L 1416.5,-378.1 L 1419.2,-387.7 L 1409.4,-392 L 1412.9,-397.9 L 1422.9,-403.8 L 1411.4,-412.3 L 1417,-423.1 L 1429.7,-416.2 L 1437.3,-415.4 L 1438.7,-404.3 L 1454,-402.1 L 1468.8,-402.4 L 1478,-399.6 L 1470.6,-386.1 L 1463.5,-385.2 L 1458.5,-376.1 L 1467.3,-367.8 L 1469.9,-378 L 1474.3,-378 L 1482.8,-352.7 Z" />
              <!-- Markers at each country's real capital city (Kathmandu, Dhaka) -->
              <circle class="why-india-dot" cx="1365.2" cy="-443.5" r="5" />
              <circle class="why-india-dot" cx="1446.6" cy="-381" r="5" />
            </svg>
            <p class="why-india-caption">
              Current export markets:<br />
              {exportMarkets.join(' • ')}
            </p>
          </div>
        </div>
      </div>

      <div class="why-quality">
        <div class="why-quality-text">
          <h3 class="why-quality-title">Quality Controlled Manufacturing</h3>
          <p class="why-quality-desc">Every production batch is inspected against defined quality parameters before dispatch to ensure consistent viscosity, gel time and batch performance.</p>
          <ul class="why-quality-list">
            <li class="why-quality-feature"><span class="why-quality-check" aria-hidden="true">✓</span>Batch Consistency</li>
            <li class="why-quality-feature"><span class="why-quality-check" aria-hidden="true">✓</span>Viscosity Verification</li>
            <li class="why-quality-feature"><span class="why-quality-check" aria-hidden="true">✓</span>Gel Time Testing</li>
            <li class="why-quality-feature"><span class="why-quality-check" aria-hidden="true">✓</span>Visual Quality Inspection</li>
          </ul>
        </div>
        <figure class="why-quality-photo">
          <div class="why-quality-frame">
            <Image src={qcLaboratory} alt="Quality inspection laboratory at Samrat Poly Resins" widths={[480, 900, 1600]} sizes="(max-width: 760px) 100vw, 560px" loading="lazy" />
          </div>
          <figcaption class="why-quality-caption">Quality Inspection Laboratory</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- ================= PRODUCTION INFRASTRUCTURE ================= -->
  <section class="section facility">
    <div class="wrap facility-grid">
      <div class="facility-text">
        <div class="section-head">
          <p class="eyebrow">Our Facility</p>
          <h2>Production Infrastructure</h2>
        </div>
        <p class="facility-desc">Our manufacturing facility is equipped with industrial resin processing equipment designed for reliable batch production, consistent product quality and efficient manufacturing operations.</p>
        <ul class="facility-list">
          <li class="facility-feature"><span class="facility-check" aria-hidden="true">✓</span>Stainless Steel Processing Equipment</li>
          <li class="facility-feature"><span class="facility-check" aria-hidden="true">✓</span>Batch Manufacturing Process</li>
          <li class="facility-feature"><span class="facility-check" aria-hidden="true">✓</span>Industrial Production Facility</li>
          <li class="facility-feature"><span class="facility-check" aria-hidden="true">✓</span>Quality-Controlled Operations</li>
        </ul>
      </div>
      <figure class="facility-photo">
        <div class="facility-frame">
          <Image src={productionInfrastructure} alt="Stainless-steel resin processing reactors at the Samrat Poly Resins manufacturing facility" widths={[480, 900, 1452]} sizes="(max-width: 760px) 100vw, 560px" loading="lazy" />
        </div>
        <figcaption class="facility-caption">Industrial Resin Manufacturing Facility</figcaption>
      </figure>
    </div>
  </section>

  <!-- ================= INDUSTRIES WE SERVE ================= -->
  <section class="section industries">
    <div class="wrap">
      <div class="section-head">
        <p class="eyebrow">Applications</p>
        <h2>Industries We Serve</h2>
      </div>
      <p class="industries-desc">Supplying high-performance resin solutions for a wide range of industrial manufacturing applications.</p>

      <div class="industry-grid">
        <div class="industry-card">
          <span class="industry-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3 L21 8 L12 13 L3 8 Z" /><path d="M3 13 L12 18 L21 13" /><path d="M3 17.5 L12 22.5 L21 17.5" /></svg>
          </span>
          <h3 class="industry-name">FRP Manufacturers</h3>
        </div>
        <div class="industry-card">
          <span class="industry-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="7" ry="2.5" /><path d="M5 5 L5 19 A7 2.5 0 0 0 19 19 L19 5" /></svg>
          </span>
          <h3 class="industry-name">Water Tank Manufacturers</h3>
        </div>
        <div class="industry-card">
          <span class="industry-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="1" /><circle cx="15.3" cy="12" r="0.9" fill="currentColor" stroke="none" /></svg>
          </span>
          <h3 class="industry-name">Door Skin Manufacturers</h3>
        </div>
        <div class="industry-card">
          <span class="industry-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2 8 L7 4 L12 8 L17 4 L22 8" /><path d="M2 13 L7 9 L12 13 L17 9 L22 13" /><path d="M2 18 L7 14 L12 18 L17 14 L22 18" /></svg>
          </span>
          <h3 class="industry-name">Roofing Sheet Manufacturers</h3>
        </div>
        <div class="industry-card">
          <span class="industry-icon" aria-hidden="true">
