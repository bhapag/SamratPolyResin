---
import Base from '../../layouts/Base.astro';
import ResourceCard from '../../components/ResourceCard.astro';
import { resources } from '../../data/resources.js';
---
<Base
  title="Knowledge Centre"
  description="Technical articles, application guides and educational resources on polyester resin manufacturing, industrial applications and best practices."
>
  <div class="wrap crumb">
    <a href="/">Home</a><span>/</span><span class="cur">Resources</span>
  </div>

  <section class="section kc-hero">
    <div class="wrap">
      <p class="eyebrow">Technical Resources</p>
      <h1>Knowledge Centre</h1>
      <p class="kc-hero-sub">Technical articles, application guides and educational resources on polyester resin manufacturing, industrial applications and best practices.</p>
    </div>
  </section>

  <section class="section kc-list">
    <div class="wrap">
      <div class="kc-grid">
        {resources.map((resource) => <ResourceCard resource={resource} />)}
      </div>
    </div>
  </section>

  <style>
    .crumb {
      display: flex; gap: 0.6rem; align-items: center; padding-top: 1.5rem;
      font-family: var(--font-mono); font-size: 0.74rem; color: var(--ink-faint); letter-spacing: 0.04em;
    }
    .crumb a:hover { color: var(--amber-2); }
    .crumb .cur { color: var(--ink-dim); }

    .kc-hero { padding-bottom: 0; }
    .kc-hero h1 { font-size: clamp(2.2rem, 6vw, 3.6rem); margin-top: 0.6rem; }
    .kc-hero-sub { color: var(--ink-dim); margin-top: 0.9rem; max-width: 60ch; }

    .kc-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.1rem; }
  </style>
</Base>
