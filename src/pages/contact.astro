---
import Base from '../layouts/Base.astro';
import EnquiryForm from '../components/EnquiryForm.astro';
import { site } from '../data/site.js';

const waLink = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent("Hi, I'd like to enquire about your resins.")}`;
---
<Base title="Contact" description={`Get in touch with ${site.name} — request a quote by phone, WhatsApp, email or the enquiry form.`}>
  <section class="section contact">
    <div class="wrap contact-grid">
      <div class="contact-info">
        <p class="eyebrow">Get in touch</p>
        <h1>Request a quote.</h1>
        <p class="contact-lead">
          Tell us the grade and quantity you need. We send prices quickly —
          or reach us directly on WhatsApp or phone.
        </p>
        <div class="contact-lines">
          <a href={`tel:${site.phoneDial}`} class="cline">
            <span class="cline-k">Phone</span>{site.phoneDisplay}
          </a>
          <a href={`mailto:${site.email}`} class="cline">
            <span class="cline-k">Email</span>{site.email}
          </a>
          <a href={waLink} target="_blank" rel="noopener" class="cline">
            <span class="cline-k">WhatsApp</span>Chat now
          </a>
          <div class="cline">
            <span class="cline-k">Address</span>
            {site.address.line1}, {site.address.line2} — {site.address.pin}
          </div>
        </div>
        <div class="map-embed">
          <iframe
            title="Location map"
            src={`https://www.google.com/maps?q=${site.mapsQuery}&output=embed`}
            loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
      </div>
      <div class="contact-form">
        <EnquiryForm />
      </div>
    </div>
  </section>

  <style>
    .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 6vw, 4rem); }
    .contact-info h1 { font-size: clamp(2.2rem, 6vw, 3.6rem); margin-top: 0.6rem; }
    .contact-lead { color: var(--ink-dim); margin-top: 1rem; max-width: 40ch; }
    .contact-lines { margin-top: 1.8rem; display: flex; flex-direction: column; gap: 0.1rem; }
    .cline {
      display: grid; grid-template-columns: 90px 1fr; align-items: center; gap: 0.8rem;
      padding: 0.85rem 0; border-top: 1px solid var(--line); font-size: 0.95rem; color: var(--ink);
    }
    .cline:last-child { border-bottom: 1px solid var(--line); }
    a.cline:hover { color: var(--amber-2); }
    .cline-k { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-faint); }
    .map-embed { margin-top: 1.8rem; border: 1px solid var(--line); aspect-ratio: 16 / 10; }
    .map-embed iframe { width: 100%; height: 100%; border: 0; filter: grayscale(0.3) contrast(1.05); }
    .contact-form { background: var(--bg-3); border: 1px solid var(--line); padding: clamp(1.4rem, 4vw, 2.2rem); align-self: start; }
    @media (max-width: 820px) { .contact-grid { grid-template-columns: 1fr; } }
  </style>
</Base>
