---
import Base from '../../layouts/Base.astro';
import ProductCard from '../../components/ProductCard.astro';
import { products, CATEGORIES } from '../../data/products.js';

const byCat = CATEGORIES.map(cat => ({ cat, items: products.filter(p => p.category === cat) })).filter(g => g.items.length);
const catId = (cat) => cat.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
---
<Base title="Products" description="Full product range from Samrat Poly Resins — polyester, GP, fire-retardant and coating resins, hardeners and FRP raw materials.">
  <section class="section prod-hero">
    <div class="wrap">
      <p class="eyebrow">Product range</p>
      <h1>What we manufacture</h1>
      <p class="prod-hero-sub">{products.length} resin grades and FRP raw materials, organised by category.</p>
    </div>
  </section>

  <section class="prod-filter-bar">
    <div class="wrap prod-filter-inner">
      <div class="prod-search">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
        <input type="search" id="prodSearch" placeholder="Search products by name…" aria-label="Search products by name" autocomplete="off" />
      </div>
      <div class="prod-chips" id="prodChips" role="list" aria-label="Filter by category">
        <button type="button" class="prod-chip is-active" data-chip-cat="all">Unsaturated Polyester Resin (UPR) ({products.length})</button>
        {byCat.map((group, i) => (
          <button type="button" class="prod-chip" data-chip-cat={group.cat} data-chip-primary={i < 2 ? 'true' : undefined}>{group.cat} ({group.items.length})</button>
        ))}
        <div class="prod-chips-fade" aria-hidden="true"></div>
      </div>
      <button type="button" class="prod-chips-toggle" id="chipsToggle" aria-expanded="false" aria-controls="prodChips" hidden>
        <span class="toggle-label">View All Categories</span>
        <svg class="toggle-chevron" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6" /></svg>
      </button>
      <p class="prod-filter-empty" id="prodFilterEmpty" hidden>No products match your search.</p>
    </div>
  </section>

  <section class="section prod-list">
    <div class="wrap">
      {byCat.map(group => (
        <div class="cat-block" id={catId(group.cat)} data-cat-block={group.cat}>
          <h2 class="cat-title"><span>{group.cat}</span><span class="cat-count">{String(group.items.length).padStart(2,'0')}</span></h2>
          <div class="grid">
            {group.items.map(p => <ProductCard product={p} />)}
          </div>
        </div>
      ))}
    </div>
  </section>

  <script>
    document.addEventListener('astro:page-load', () => {
      const searchInput = document.getElementById('prodSearch') as HTMLInputElement | null;
      const chips = document.querySelectorAll<HTMLButtonElement>('[data-chip-cat]');
      const blocks = document.querySelectorAll<HTMLElement>('[data-cat-block]');
      const emptyMsg = document.getElementById('prodFilterEmpty');
      if (!searchInput || !blocks.length || searchInput.dataset.wired === 'true') return;
      searchInput.dataset.wired = 'true';

      let activeCategory = 'all';

      const applyFilter = () => {
        const query = searchInput.value.trim().toLowerCase();
        let anyVisible = false;

        blocks.forEach((block) => {
          const blockCat = block.dataset.catBlock ?? '';
          const catMatches = activeCategory === 'all' || blockCat === activeCategory;
          let blockHasVisibleCard = false;

          block.querySelectorAll<HTMLElement>('[data-product-card]').forEach((card) => {
            const searchText = card.dataset.search ?? '';
            const matches = catMatches && (query === '' || searchText.includes(query));
            card.style.display = matches ? '' : 'none';
            if (matches) blockHasVisibleCard = true;
          });

          block.hidden = !blockHasVisibleCard;
          if (blockHasVisibleCard) anyVisible = true;
        });

        if (emptyMsg) emptyMsg.hidden = anyVisible;
      };

      searchInput.addEventListener('input', applyFilter);

      chips.forEach((chip) => {
        chip.addEventListener('click', () => {
          activeCategory = chip.dataset.chipCat ?? 'all';
          chips.forEach((c) => c.classList.toggle('is-active', c === chip));
          applyFilter();
        });
      });

      // Mobile-only chip collapse: clip the category list right after the
      // last "primary" chip's own row so it never cuts a chip in half, and
      // only offer the toggle if there's actually more to reveal.
      const chipsEl = document.getElementById('prodChips');
      const toggleBtn = document.getElementById('chipsToggle') as HTMLButtonElement | null;
      const toggleLabel = toggleBtn?.querySelector('.toggle-label');
      if (chipsEl && toggleBtn && toggleLabel) {
        const mobileQuery = window.matchMedia('(max-width: 620px)');
        const secondaryChips = Array.from(chipsEl.querySelectorAll<HTMLButtonElement>('.prod-chip')).filter(
          (c) => c.dataset.chipCat !== 'all' && !c.hasAttribute('data-chip-primary')
        );

        // While collapsed on mobile, the secondary chips are visually clipped
        // (overflow:hidden, not scrollable) — pull them out of tab order and
        // the accessibility tree so keyboard/AT users don't land on controls
        // they can't see, and always meet them again once expanded.
        const setSecondaryReachable = (reachable: boolean) => {
          secondaryChips.forEach((c) => {
            if (reachable) { c.removeAttribute('tabindex'); c.removeAttribute('aria-hidden'); }
            else { c.setAttribute('tabindex', '-1'); c.setAttribute('aria-hidden', 'true'); }
          });
        };

        const measure = () => {
          if (chipsEl.classList.contains('is-expanded')) return;
          if (!mobileQuery.matches) {
            toggleBtn.hidden = true;
            setSecondaryReachable(true);
            return;
          }
          const primaryChips = chipsEl.querySelectorAll<HTMLElement>('[data-chip-primary]');
          const lastPrimary = primaryChips[primaryChips.length - 1];
          if (!lastPrimary) { toggleBtn.hidden = true; setSecondaryReachable(true); return; }
          const collapsedH = Math.ceil(lastPrimary.getBoundingClientRect().bottom - chipsEl.getBoundingClientRect().top) + 10;
          chipsEl.style.setProperty('--chips-collapsed-h', `${collapsedH}px`);
          const overflowing = chipsEl.scrollHeight > collapsedH + 4;
          toggleBtn.hidden = !overflowing;
          setSecondaryReachable(!overflowing);
        };

        toggleBtn.addEventListener('click', () => {
          const nowExpanded = !chipsEl.classList.contains('is-expanded');
          chipsEl.classList.toggle('is-expanded', nowExpanded);
          toggleBtn.setAttribute('aria-expanded', String(nowExpanded));
          toggleLabel.textContent = nowExpanded ? 'Show Fewer Categories' : 'View All Categories';
          setSecondaryReachable(nowExpanded);
          if (!nowExpanded) measure();
        });

        measure();
        window.addEventListener('resize', measure);
      }
    });
  </script>

  <style>
    .prod-hero { padding-bottom: 0; }
    .prod-hero h1 { font-size: clamp(2.2rem, 6vw, 3.6rem); margin-top: 0.6rem; }
    .prod-hero-sub { color: var(--ink-dim); margin-top: 0.9rem; max-width: 48ch; }

    .prod-filter-bar { padding-block: 1.6rem; position: sticky; top: 68px; z-index: 20; background: var(--bg); border-bottom: 1px solid var(--line); }
    .prod-filter-inner { display: flex; flex-direction: column; gap: 1rem; }
    .prod-search {
      display: flex; align-items: center; gap: 0.6rem;
      border: 1px solid var(--line-2); background: var(--bg-3); padding: 0.7rem 1rem;
      max-width: 420px; color: var(--ink-faint); transition: border-color .25s var(--ease-premium);
    }
    .prod-search:focus-within { border-color: var(--accent-gold); color: var(--accent-gold); }
    .prod-search input {
      flex: 1; background: transparent; border: none; outline: none;
      color: var(--ink); font-family: var(--font-body); font-size: 0.92rem;
    }
    .prod-search input::placeholder { color: var(--ink-faint); }
    .prod-chips { display: flex; flex-wrap: wrap; gap: 0.6rem; }
    .prod-chip {
      font-family: var(--font-mono); font-size: 0.76rem; letter-spacing: 0.03em;
      padding: 0.45rem 0.9rem; border: 1px solid var(--line-2); background: transparent;
      color: var(--ink-dim); cursor: pointer;
      transition: border-color .25s var(--ease-premium), color .25s var(--ease-premium), background .25s var(--ease-premium);
    }
    .prod-chip:hover { border-color: var(--accent-gold); color: var(--accent-gold-light); }
    .prod-chip.is-active { background: var(--accent-gold); border-color: var(--accent-gold); color: #17120c; font-weight: 600; }
    .prod-filter-empty { color: var(--ink-dim); font-size: 0.92rem; margin-top: 0.2rem; }
    .prod-chips-fade { display: none; }
    .prod-chips-toggle {
      display: none;
      align-items: center; justify-content: center; gap: 0.4rem;
      width: 100%; margin-top: -0.2rem;
      font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.05em; text-transform: uppercase;
      color: var(--accent-gold-light); background: transparent; border: none;
      padding: 0.6rem; cursor: pointer;
    }
    .prod-chips-toggle .toggle-chevron { transition: transform .3s var(--ease-premium); }
    .prod-chips-toggle[aria-expanded="true"] .toggle-chevron { transform: rotate(180deg); }
    @media (max-width: 620px) {
      .prod-search { max-width: none; }
      .prod-chip { padding: 0.75rem 1rem; }
      .prod-chips {
        max-height: var(--chips-collapsed-h, 108px);
        overflow: hidden;
        position: relative;
        transition: max-height .45s var(--ease-premium);
      }
      .prod-chips.is-expanded { max-height: 600px; }
      .prod-chips-fade {
        display: block; position: absolute; left: 0; right: 0; bottom: 0; height: 2.4rem;
        background: linear-gradient(180deg, transparent, var(--bg));
        pointer-events: none; opacity: 1; transition: opacity .3s var(--ease-premium);
      }
      .prod-chips.is-expanded .prod-chips-fade { opacity: 0; }
      .prod-chips-toggle:not([hidden]) { display: flex; }
    }

    .cat-block { margin-bottom: 3.2rem; scroll-margin-top: 90px; }
    .cat-block[hidden] { display: none; }
    .cat-title {
      display: flex; align-items: baseline; gap: 1rem;
      font-size: 1.25rem; color: var(--ink-dim); margin-bottom: 1.3rem;
      padding-bottom: 0.7rem; border-bottom: 1px solid var(--line);
    }
    .cat-title span:first-child { color: var(--ink); letter-spacing: 0.05em; }
    .cat-count { font-family: var(--font-mono); font-size: 0.8rem; color: var(--accent-gold); margin-left: auto; }
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(270px, 1fr)); gap: 1.4rem; }
  </style>
</Base>
