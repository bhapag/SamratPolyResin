---
import { getImage } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import EnquiryForm from '../../components/EnquiryForm.astro';
import { products } from '../../data/products.js';
import { site, buildProductQuoteLink, buildCanonicalUrl } from '../../data/site.js';

export function getStaticPaths() {
  return products.map(p => ({ params: { slug: p.slug }, props: { product: p } }));
}

const productImageModules = import.meta.glob('/src/assets/products/*', { eager: true });
const resolveProductImage = (filename) => productImageModules[`/src/assets/products/${filename}`]?.default;

const { product } = Astro.props;
const { name, image, description, features, applications, category, specs } = product;
const specEntries = specs ? Object.entries(specs) : [];
const gallery = [image, ...(product.images ?? [])];

// Resolve each gallery photo to an optimised, compressed webp — one size for
// the large main viewer, one for the thumbnail strip. The thumbnail's
// `data-src` carries the main-size URL so the click-to-swap script (below)
// can assign it straight to the main <img>'s src.
const galleryImages = await Promise.all(
  gallery.map(async (filename) => {
    const mod = resolveProductImage(filename);
    if (!mod) return null;
    const [main, thumb] = await Promise.all([
      getImage({ src: mod, width: 700, format: 'webp' }),
      getImage({ src: mod, width: 160, format: 'webp' }),
    ]);
    return { main, thumb };
  })
);
const mainImage = galleryImages[0];

const related = products.filter(p => p.category === category && p.slug !== product.slug).slice(0, 3);
const waLink = buildProductQuoteLink(product.whatsappName ?? name);

// BreadcrumbList — mirrors the visible breadcrumb below exactly, no extra data.
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: buildCanonicalUrl('/') },
    { "@type": "ListItem", position: 2, name: "Products", item: buildCanonicalUrl('/products/') },
    { "@type": "ListItem", position: 3, name, item: buildCanonicalUrl(Astro.url.pathname) },
  ],
};

// Product schema — deliberately omits `offers`/price. Pricing here is
// "Price on Request" (varies by quantity and current raw-material rates),
// and Schema.org Offers without a real price fail Google's structured-data
// validation — better to omit it than publish a placeholder number.
const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  name,
  description,
  category,
  image: mainImage ? buildCanonicalUrl(mainImage.main.src) : undefined,
  brand: { "@type": "Organization", name: site.name },
  manufacturer: { "@type": "Organization", name: site.name },
};
---
<Base title={name} description={`${name} — ${product.tagline} Manufactured by ${site.name}.`}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(productJsonLd)} />

  <div class="wrap crumb">
    <a href="/">Home</a><span>/</span><a href="/products/">Products</a><span>/</span><span class="cur">{name}</span>
  </div>

  <article class="wrap prod">
    <div class="prod-media">
      <div class="prod-media-sticky">
        <div class:list={['prod-img', { noimg: !mainImage }]}>
          {mainImage && (
            <img src={mainImage.main.src} width={mainImage.main.attributes.width} height={mainImage.main.attributes.height}
                 alt={name} id="prodMainImg"
                 transition:name={`product-photo-${product.slug}`} />
          )}
          <span class="img-fallback" aria-hidden="true">{name.split(' ').map(w=>w[0]).join('').slice(0,3)}</span>
        </div>
        {gallery.length > 1 && (
          <div class="prod-thumbs" role="list">
            {galleryImages.map((g, i) => g && (
              <button type="button" class:list={['prod-thumb', { active: i === 0 }]} data-src={g.main.src} aria-label={`Show photo ${i + 1} of ${name}`}>
                <img src={g.thumb.src} width={g.thumb.attributes.width} height={g.thumb.attributes.height} alt="" loading="lazy" />
              </button>
            ))}
          </div>
        )}
      </div>
    </div>

    <div class="prod-info">
      <span class="prod-cat">{category}</span>
      <h1 class="prod-name" transition:name={`product-name-${product.slug}`}>{name}</h1>
      <div class="prod-quote">
        <p class="prod-quote-heading">Price</p>
        <p class="prod-quote-value">{site.priceLabel}</p>
        <p class="prod-quote-note">Industrial resin pricing varies based on:</p>
        <ul class="prod-quote-list">
          <li>Order Quantity</li>
          <li>Resin Grade</li>
          <li>Current Raw Material Rates</li>
        </ul>
        <a href={waLink} class="btn btn-solid prod-quote-cta" target="_blank" rel="noopener">Request Bulk Quote</a>
      </div>

      <div class="prod-cta">
        <a href="#enquire" class="btn btn-solid">Enquire / get quote</a>
        <a href={waLink} class="btn btn-wa" target="_blank" rel="noopener">WhatsApp</a>
      </div>

      {specEntries.length > 0 && (
        <div class="specs-table-wrap">
          <h2 class="spec-h">Product details</h2>
          <table class="specs-table">
            <tbody>
              {specEntries.map(([k, v]) => (
                <tr><th>{k}</th><td>{v}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

      <p class="prod-desc">{description}</p>

      <div class="spec-grid">
        <div class="spec-col">
          <h2 class="spec-h">Key features</h2>
          <ul>{features.map(f => <li>{f}</li>)}</ul>
        </div>
        <div class="spec-col">
          <h2 class="spec-h">Applications</h2>
          <ul>{applications.map(a => <li>{a}</li>)}</ul>
        </div>
      </div>
    </div>
  </article>

  {related.length > 0 && (
    <section class="wrap related">
      <h2 class="rel-h">More in {category}</h2>
      <div class="rel-grid">
        {related.map(r => (
          <a href={`/products/${r.slug}/`} class="rel-card">
            <span class="rel-name">{r.name}</span>
            <span class="rel-price">{site.priceLabel}</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <section id="enquire" class="section enquire-sec">
    <div class="wrap enquire-inner">
      <div class="section-head">
        <p class="eyebrow">Enquiry</p>
        <h2>Get a quote for {name}</h2>
      </div>
      <div class="enquire-box">
        <EnquiryForm product={name} />
      </div>
    </div>
  </section>

  <script>
    document.addEventListener('astro:page-load', () => {
      document.querySelectorAll<HTMLButtonElement>('.prod-thumb').forEach((btn) => {
        btn.addEventListener('click', () => {
          const main = document.getElementById('prodMainImg') as HTMLImageElement | null;
          const src = btn.dataset.src;
          if (!main || !src || main.src.endsWith(src)) return;
          main.classList.add('fading');
          window.setTimeout(() => {
            main.src = src;
            main.classList.remove('fading');
          }, 140);
          document.querySelectorAll('.prod-thumb').forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
        });
      });
    });
  </script>

  <style>
    .crumb {
      display: flex; gap: 0.6rem; align-items: center; padding-top: 1.5rem;
      font-family: var(--font-mono); font-size: 0.74rem; color: var(--ink-faint); letter-spacing: 0.04em;
    }
    .crumb a:hover { color: var(--accent-gold-light); }
    .crumb .cur { color: var(--ink-dim); }

    .prod { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: clamp(1.5rem, 5vw, 3.5rem); padding-block: 2.2rem 3rem; }
    .prod-media-sticky { position: sticky; top: 90px; }
    .prod-img {
      position: relative; aspect-ratio: 4 / 3; border: 1px solid var(--image-frame-border); border-radius: 14px;
      background: linear-gradient(135deg, #1a1e24, #23282f);
      display: grid; place-items: center; overflow: hidden;
      box-shadow: var(--image-frame-shadow);
      transition: box-shadow .4s var(--ease-premium);
    }
    .prod-img:hover { box-shadow: 0 1px 0 rgba(255, 255, 255, .08) inset, 0 22px 48px rgba(0, 0, 0, .46); }
    .prod-img img { width: 100%; height: 100%; object-fit: cover; transition: opacity .14s ease, transform .5s var(--ease-premium); }
    .prod-img:hover img:not(.fading) { transform: scale(1.03); }
    .prod-img img.fading { opacity: 0; }
    .img-fallback { display: none; position: absolute; font-family: var(--font-display); font-weight: 700; font-size: 3.5rem; color: var(--line-2); }
    .prod-img.noimg .img-fallback { display: block; }

    .prod-thumbs { display: flex; gap: 0.7rem; margin-top: 0.9rem; flex-wrap: wrap; }
    .prod-thumb {
      padding: 0; border: 1px solid var(--line); background: var(--bg-3); cursor: pointer;
      width: 76px; aspect-ratio: 4 / 3; overflow: hidden; transition: border-color .3s var(--ease-premium), transform .3s var(--ease-premium);
    }
    .prod-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .prod-thumb:hover { border-color: var(--line-2); transform: translateY(-1px); }
    .prod-thumb.active { border-color: var(--accent-gold); }

    .prod-cat { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent-gold); }
    .prod-name { font-size: clamp(2rem, 5vw, 3.2rem); margin-top: 0.6rem; text-transform: none; letter-spacing: 0; }
    .prod-quote {
      display: flex; flex-direction: column; gap: 0.5rem; margin-top: 0.9rem; max-width: 420px;
      padding: 1.1rem 1.3rem; background: var(--bg-3); border: 1px solid var(--line); box-shadow: var(--surface-shadow-rest);
    }
    .prod-quote-heading { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-faint); }
    .prod-quote-value { font-family: var(--font-display); font-size: 1.3rem; text-transform: uppercase; letter-spacing: 0.02em; color: var(--accent-gold-light); }
    .prod-quote-note { color: var(--ink-dim); font-size: 0.88rem; margin-top: 0.3rem; }
    .prod-quote-list { list-style: none; display: flex; flex-direction: column; gap: 0.65rem; }
    .prod-quote-list li {
      position: relative; padding-left: 1.6rem; color: var(--ink); font-size: 0.88rem; font-weight: 600;
      line-height: 1.6; text-shadow: 0 1px 3px rgba(0, 0, 0, .22);
      transition: color .25s var(--ease-premium), transform .25s var(--ease-premium);
    }
    .prod-quote-list li:hover { color: #ffffff; transform: translateX(3px); }
    .prod-quote-list li::before {
      content: '✓'; position: absolute; left: 0; top: 50%; transform: translateY(-50%);
      display: flex; align-items: center; justify-content: center;
      width: 16px; height: 16px; border-radius: 50%;
      background: linear-gradient(180deg, var(--accent-gold-light), var(--accent-gold-dark));
      color: #17120c; font-size: 0.56rem; font-weight: 700; line-height: 1;
      box-shadow: 0 0 0 1px rgba(var(--gold-rgb), .3), 0 1px 4px rgba(0, 0, 0, .3);
      transition: box-shadow .25s var(--ease-premium), transform .25s var(--ease-premium);
    }
    .prod-quote-list li:hover::before {
      box-shadow: 0 0 10px rgba(var(--gold-rgb), .5), 0 0 0 1px rgba(var(--gold-rgb), .45);
      transform: translateY(-50%) scale(1.08);
    }
    .prod-quote-cta { align-self: flex-start; margin-top: 0.5rem; }
    .prod-desc { color: var(--ink-dim); margin-top: 1.6rem; font-size: 1rem; }
    .prod-cta { display: flex; gap: 0.8rem; margin-top: 1.4rem; flex-wrap: wrap; }

    .specs-table-wrap { margin-top: 2rem; }
    .specs-table { width: 100%; border-collapse: collapse; border: 1px solid var(--line); font-size: 0.88rem; }
    .specs-table th, .specs-table td { padding: 0.6rem 0.9rem; border-top: 1px solid var(--line); text-align: left; font-weight: 400; }
    .specs-table tr:first-child th, .specs-table tr:first-child td { border-top: none; }
    .specs-table th {
      width: 42%; color: var(--ink-faint); font-family: var(--font-mono); font-size: 0.72rem;
      letter-spacing: 0.06em; text-transform: uppercase; background: var(--bg-3);
    }
    .specs-table td { color: var(--ink); background: var(--bg-2); }

    .spec-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-top: 2.5rem; padding-top: 2rem; border-top: 1px solid var(--line); }
    .spec-h { font-size: 0.8rem; letter-spacing: 0.14em; color: var(--ink); margin-bottom: 1rem; }
    .spec-col ul { list-style: none; display: flex; flex-direction: column; gap: 0.85rem; }
    .spec-col li {
      position: relative; padding-left: 1.7rem; color: var(--ink); font-size: 0.92rem; font-weight: 600;
      line-height: 1.6; text-shadow: 0 1px 3px rgba(0, 0, 0, .22);
      transition: color .25s var(--ease-premium), transform .25s var(--ease-premium);
    }
    .spec-col li:hover { color: #ffffff; transform: translateX(3px); }
    .spec-col li::before {
      content: '✓'; position: absolute; left: 0; top: 50%; transform: translateY(-50%);
      display: flex; align-items: center; justify-content: center;
      width: 18px; height: 18px; border-radius: 50%;
      background: linear-gradient(180deg, var(--accent-gold-light), var(--accent-gold-dark));
      color: #17120c; font-size: 0.6rem; font-weight: 700; line-height: 1;
      box-shadow: 0 0 0 1px rgba(var(--gold-rgb), .3), 0 1px 4px rgba(0, 0, 0, .3);
      transition: box-shadow .25s var(--ease-premium), transform .25s var(--ease-premium);
    }
    .spec-col li:hover::before {
      box-shadow: 0 0 10px rgba(var(--gold-rgb), .5), 0 0 0 1px rgba(var(--gold-rgb), .45);
      transform: translateY(-50%) scale(1.08);
    }
    @media (max-width: 860px) { .prod { grid-template-columns: 1fr; } .prod-media-sticky { position: relative; top: 0; } }
    @media (max-width: 460px) { .spec-grid { grid-template-columns: 1fr; gap: 1.5rem; } }

    .related { padding-block: 1rem 3rem; }
    .rel-h { font-size: 1.1rem; color: var(--ink-dim); margin-bottom: 1.2rem; }
    .rel-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 0.9rem; }
    .rel-card {
      display: flex; flex-direction: column; gap: 0.4rem; padding: 1rem 1.1rem;
      background: var(--bg-3); border: 1px solid var(--line); box-shadow: var(--surface-shadow-rest);
      transition: border-color .3s var(--ease-premium), transform .3s var(--ease-premium), box-shadow .3s var(--ease-premium);
    }
    .rel-card:hover { border-color: var(--accent-gold); transform: translateY(-2px); box-shadow: var(--surface-shadow-hover); }
    .rel-name { font-family: var(--font-display); text-transform: uppercase; font-size: 0.95rem; }
    .rel-price { font-family: var(--font-mono); font-size: 0.8rem; color: var(--accent-gold-light); }

    .enquire-sec { position: relative; background: linear-gradient(180deg, transparent, var(--bg-2) 64px); }
    .enquire-sec::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
      background: linear-gradient(90deg, transparent, var(--line-2) 20%, var(--line-2) 80%, transparent);
    }
    .enquire-inner { max-width: 720px; }
    .enquire-box { background: var(--bg-3); border: 1px solid var(--line); box-shadow: var(--surface-shadow-rest); padding: clamp(1.4rem, 4vw, 2.2rem); }
  </style>
</Base>
