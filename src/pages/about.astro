---
import Base from '../layouts/Base.astro';
import { site } from '../data/site.js';
import { products, CATEGORIES } from '../data/products.js';

const years = new Date().getFullYear() - Number(site.established);
---
<Base title="About us" description={`About ${site.name} — manufacturer of GP Polyester, Gel Coat, Fire Retardant, Epoxy and Specialty Resin systems in ${site.address.line2}, ${site.address.state}. Established ${site.established}.`}>
  <section class="section about-hero">
    <div class="wrap">
      <p class="eyebrow">About {site.name}</p>
      <h1>
        Engineered for<br/>
        <span class="hl">quality</span>.<br/>
        Built for<br/>
        <span class="hl">consistency</span>.
      </h1>
      <p class="about-lead">
        Established in {site.established}, {site.name} is a Punjab-based
        manufacturer of GP Polyester, Gel Coat, Fire Retardant, Epoxy and
        Specialty Resin systems serving composite manufacturers across India.
      </p>
    </div>
  </section>

  <section class="section about-body">
    <div class="wrap about-grid">
      <div class="about-copy">
        <figure class="about-photo">
          <img src="/about/factory-gate.jpg" alt={`${site.name} factory gate, ${site.address.line2}`} width="1448" height="1086" loading="lazy" />
          <figcaption>Our facility — {site.address.line2}, {site.address.state}</figcaption>
        </figure>
        <p>
          Our resins are produced on modern processing equipment, using raw
          materials sourced from established vendors. Each batch is
          manufactured to a defined specification and checked for consistent
          viscosity, gel time and cure behaviour before it is approved.
        </p>
        <p>
          Every batch is inspected against our quality parameters ahead of
          dispatch, confirming it matches both the specification and prior
          production runs. That consistency, backed by reliable production
          capacity, lets fabricators plan their own manufacturing schedules
          with confidence.
        </p>
        <a href="/products/" class="btn btn-solid">View our products</a>
      </div>

      <ul class="about-facts">
        <li><span>Proprietor</span>{site.proprietor}</li>
        <li><span>Business</span>Manufacturer</li>
        <li><span>Location</span>{site.address.line2}, {site.address.state}</li>
        <li><span>GSTIN</span>{site.gst}</li>
        <li><span>Established</span>{site.established} ({years}+ yrs)</li>
        <li><span>Product Range</span>{products.length}+ resin grades</li>
      </ul>
    </div>
  </section>

  <section class="section about-cats">
    <div class="wrap">
      <div class="section-head">
        <p class="eyebrow">Categories</p>
        <h2>Our product portfolio</h2>
      </div>
      <div class="cat-grid">
        {CATEGORIES.map(cat => (
          <a href={`/products/#${cat.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}`} class="cat-tile">
            <span class="cat-tile-name">{cat}</span>
            <span class="cat-tile-count">{products.filter(p => p.category === cat).length} grades</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <style>
    .about-hero { padding-bottom: 0; }
    .about-hero h1 { font-size: clamp(1.9rem, 5vw, 3.1rem); margin-top: 0.6rem; }
    .about-hero h1 .hl { color: var(--amber); }
    .about-lead { color: var(--ink-dim); margin-top: 1.3rem; max-width: 52ch; font-size: 1.05rem; }

    .about-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: clamp(1.5rem, 5vw, 4rem); }
    .about-copy p { color: var(--ink-dim); margin-bottom: 1.1rem; }
    .about-copy .btn { margin-top: 0.8rem; }

    .about-photo {
      border: 1px solid var(--line); margin-bottom: 1.6rem; overflow: hidden;
    }
    .about-photo img { width: 100%; height: auto; display: block; }
    .about-photo figcaption {
      padding: 0.7rem 0.9rem; border-top: 1px solid var(--line); background: var(--bg-3);
      font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.06em;
      text-transform: uppercase; color: var(--ink-faint);
    }

    .about-facts { list-style: none; display: flex; flex-direction: column; gap: 1.1rem; align-self: start; }
    .about-facts li { border-left: 2px solid var(--amber); padding-left: 0.9rem; font-size: 0.95rem; line-height: 1.5; }
    .about-facts span { display: block; font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-faint); margin-bottom: 0.25rem; }
    @media (max-width: 760px) { .about-grid { grid-template-columns: 1fr; } }

    .about-cats { background: var(--bg-2); border-top: 1px solid var(--line); }
    .cat-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); grid-auto-rows: 1fr; gap: 1rem; }
    .cat-tile {
      display: flex; flex-direction: column; justify-content: center; gap: 0.4rem; padding: 1.3rem 1.4rem; height: 100%;
      background: var(--bg-3); border: 1px solid var(--line);
      transition: border-color .3s var(--ease-premium), transform .3s var(--ease-premium), box-shadow .3s var(--ease-premium);
    }
    .cat-tile:hover {
      border-color: var(--amber); transform: translateY(-3px) scale(1.012);
      box-shadow: 0 12px 28px rgba(0, 0, 0, .28);
    }
    .cat-tile-name { font-family: var(--font-display); text-transform: uppercase; font-size: 1rem; letter-spacing: 0.03em; }
    .cat-tile-count { font-family: var(--font-mono); font-size: 0.76rem; color: var(--amber-2); }
  </style>
</Base>
