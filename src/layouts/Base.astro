---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import { site, buildCanonicalUrl } from '../data/site.js';

const { title, description, ogType = 'website', ogTitle, ogDescription, keywords } = Astro.props;
const pageTitle = title ? `${title} — ${site.name}` : `${site.name} — ${site.tagline}`;
const desc = description ?? `${site.name}: manufacturer of coating and composite resins from ${site.address.line2}, ${site.address.state}. Established ${site.established}.`;
const finalOgTitle = ogTitle ?? pageTitle;
const finalOgDesc = ogDescription ?? desc;
const waLink = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent("Hi, I'd like to enquire about your resins.")}`;
const canonicalUrl = buildCanonicalUrl(Astro.url.pathname);
const ogImageUrl = buildCanonicalUrl(site.ogImage);

// Sitewide Organization/LocalBusiness structured data — built entirely from
// the verified contact fields in site.js, nothing invented. Helps Google
// associate the business identity (name, address, phone) across the site
// rather than just per-article Article schema.
const organizationJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": `${site.url}/#organization`,
  name: site.name,
  url: site.url,
  logo: buildCanonicalUrl('/logo.jpg'),
  image: buildCanonicalUrl('/logo.jpg'),
  telephone: site.phoneDial,
  email: site.email,
  foundingDate: site.established,
  address: {
    "@type": "PostalAddress",
    streetAddress: site.address.line1,
    addressLocality: site.address.line2,
    addressRegion: "Punjab",
    postalCode: site.address.pin,
    addressCountry: "IN",
  },
};
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{pageTitle}</title>
  <meta name="description" content={desc} />
  {keywords && <meta name="keywords" content={keywords.join(', ')} />}
  <meta property="og:title" content={finalOgTitle} />
  <meta property="og:description" content={finalOgDesc} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:site_name" content={site.name} />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={finalOgTitle} />
  <meta name="twitter:description" content={finalOgDesc} />
  <meta name="twitter:image" content={ogImageUrl} />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/favicon.png" type="image/png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <script type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} />
  <ClientRouter />
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to content</a>
  <header class="site-header" transition:persist>
    <div class="wrap header-inner">
      <a href="/" class="brand">
        <img src="/logo.jpg" alt={`${site.name} logo`} class="brand-mark" width="40" height="40" />
        <span class="brand-name">{site.name}</span>
      </a>
      <nav class="nav" aria-label="Primary">
        <a href="/">Home</a>
        <a href="/products/">Products</a>
        <a href="/about/">About</a>
        <a href="/resources/">Resources</a>
        <a href="/contact/">Contact</a>
        <a href={waLink} class="nav-wa" target="_blank" rel="noopener">WhatsApp</a>
      </nav>
      <button type="button" class="nav-toggle" id="navToggle" aria-expanded="false" aria-controls="mobileNav" aria-label="Open menu">
        <span class="nav-toggle-bar" aria-hidden="true"></span>
        <span class="nav-toggle-bar" aria-hidden="true"></span>
        <span class="nav-toggle-bar" aria-hidden="true"></span>
      </button>
    </div>
    <nav class="mobile-nav" id="mobileNav" aria-label="Primary mobile">
      <a href="/">Home</a>
      <a href="/products/">Products</a>
      <a href="/about/">About</a>
      <a href="/resources/">Resources</a>
      <a href="/contact/">Contact</a>
      <a href={waLink} class="mobile-nav-wa" target="_blank" rel="noopener">WhatsApp</a>
    </nav>
  </header>

  <main id="main-content">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="wrap footer-grid">
      <div>
        <img src="/logo.jpg" alt={`${site.name} logo`} class="brand-mark big" width="64" height="64" />
        <p class="foot-name">{site.name}</p>
        <p class="foot-dim">Manufacturer of coating &amp; composite resins.<br/>Established {site.established}.</p>
      </div>
      <div>
        <h3 class="foot-h">Quick links</h3>
        <nav class="foot-nav" aria-label="Footer">
          <a href="/">Home</a>
          <a href="/products/">Products</a>
          <a href="/about/">About</a>
          <a href="/resources/">Resources</a>
          <a href="/contact/">Contact</a>
        </nav>
      </div>
      <div>
        <h3 class="foot-h">Reach us</h3>
        <p class="foot-dim">
          {site.proprietor} (Proprietor)<br/>
          {site.address.line1}<br/>
          {site.address.line2} — {site.address.pin}<br/>
          {site.address.state}
        </p>
      </div>
      <div>
        <h3 class="foot-h">Contact</h3>
        <p class="foot-dim">
          <a href={`tel:${site.phoneDial}`}>{site.phoneDisplay}</a><br/>
          <a href={`mailto:${site.email}`}>{site.email}</a><br/>
          <a href={waLink} target="_blank" rel="noopener">WhatsApp enquiry</a>
        </p>
        <p class="foot-gst">GST {site.gst}</p>
      </div>
    </div>
    <div class="wrap foot-bottom">
      <span>© {new Date().getFullYear()} {site.name}. All rights reserved.</span>
    </div>
  </footer>

  <!-- floating whatsapp -->
  <a href={waLink} class="wa-float" target="_blank" rel="noopener" aria-label="Chat on WhatsApp" transition:persist>
    <svg viewBox="0 0 24 24" width="26" height="26" fill="currentColor" aria-hidden="true"><path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.2s-.8.9-.9 1.1c-.2.2-.3.2-.6.1-.3-.2-1.2-.5-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5 0-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.5c-.2 0-.5 0-.7.3-.2.3-.9.9-.9 2.2s1 2.5 1.1 2.7c.1.2 1.9 3 4.7 4.2.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.5-.1 1.7-.7 1.9-1.4.2-.6.2-1.2.2-1.4-.1-.1-.3-.2-.6-.3zM12 2a10 10 0 0 0-8.6 15l-1.3 4.7L7 20.4A10 10 0 1 0 12 2zm0 18.2c-1.5 0-3-.4-4.3-1.2l-.3-.2-3.1.8.8-3-.2-.3A8.2 8.2 0 1 1 12 20.2z"/></svg>
  </a>

  <script>
    document.addEventListener('astro:page-load', () => {
      const toggle = document.getElementById('navToggle');
      const panel = document.getElementById('mobileNav');
      if (!toggle || !panel || toggle.dataset.wired === 'true') return;
      toggle.dataset.wired = 'true';

      const closeMenu = () => {
        toggle.setAttribute('aria-expanded', 'false');
        panel.classList.remove('is-open');
      };
      toggle.addEventListener('click', () => {
        const isOpen = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!isOpen));
        panel.classList.toggle('is-open', !isOpen);
      });
      panel.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMenu));
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMenu(); });
    });
  </script>

  <script>
    // Sitewide scroll-reveal + stagger system. Progressive enhancement only:
    // if this doesn't run (JS disabled/slow), content stays normally visible —
    // nothing is hidden by default in CSS, this script hides-then-reveals.
    document.addEventListener('astro:page-load', () => {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      const GRID_SELECTOR = [
        '.grid', '.kc-grid', '.why-grid', '.industry-grid', '.cat-grid',
        '.diagram-icongrid', '.footer-grid', '.article-related-grid',
        '.rel-grid', '.faq-accordion', '.process-list', '.quick-facts-list', '.toc-list',
        '.applications-gallery', '.applications-capabilities',
      ].join(', ');
      const IMG_SELECTOR = '.about-photo, .card-img, .prod-img, .facility-frame, .why-quality-frame';
      const HEAD_SELECTOR = '.section-head, .article-prevnext, .applications-lead, .applications-closing';

      const io = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          entry.target.classList.add('is-visible');
          io.unobserve(entry.target);
        }
      }, { threshold: 0.1, rootMargin: '0px 0px -8% 0px' });

      const tagged = new WeakSet();
      const tag = (el, cls, delayMs) => {
        if (tagged.has(el)) return;
        tagged.add(el);
        const rect = el.getBoundingClientRect();
        const alreadyVisible = rect.top < window.innerHeight * 0.9 && rect.bottom > 0;
        if (alreadyVisible) return; // already on screen at load — no reveal needed
        el.classList.add(cls);
        if (delayMs) el.style.transitionDelay = delayMs + 'ms';
        io.observe(el);
      };

      document.querySelectorAll(GRID_SELECTOR).forEach((grid) => {
        Array.from(grid.children).forEach((child, i) => {
          tag(child, 'js-reveal', Math.min(i, 8) * 70);
        });
      });

      document.querySelectorAll(IMG_SELECTOR).forEach((el) => tag(el, 'js-reveal-img', 0));
      document.querySelectorAll(HEAD_SELECTOR).forEach((el) => tag(el, 'js-reveal', 0));
    });
  </script>

  <style>
    .skip-link {
      position: absolute; top: -100%; left: 1rem; z-index: 100;
      background: var(--accent-gold); color: #17120c; font-family: var(--font-mono);
      font-size: 0.85rem; font-weight: 700; padding: 0.8rem 1.2rem;
      transition: top .2s var(--ease-premium);
    }
    .skip-link:focus { top: 1rem; }

    .site-header {
      position: sticky; top: 0; z-index: 50;
      background: color-mix(in srgb, var(--bg) 88%, transparent);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(var(--gold-rgb), .14);
      box-shadow: 0 8px 24px rgba(0, 0, 0, .22);
      animation: header-fade-in .5s var(--ease-premium) both;
    }
    @media (prefers-reduced-motion: no-preference) {
      @keyframes header-fade-in {
        from { opacity: 0; transform: translateY(-8px); }
        to   { opacity: 1; transform: translateY(0); }
      }
    }
    .header-inner { display: flex; align-items: center; justify-content: space-between; height: 68px; }
    .brand { display: flex; align-items: center; gap: 0.7rem; }
    .brand-mark {
      width: 40px; height: 40px; border-radius: 50%; object-fit: cover; flex-shrink: 0;
      box-shadow: 0 0 0 1px rgba(var(--gold-rgb), .3), 0 2px 8px rgba(0, 0, 0, .35);
    }
    .brand-mark.big { width: 64px; height: 64px; display: block; }
    .brand-name { font-family: var(--font-display); font-weight: 600; text-transform: uppercase; letter-spacing: 0.03em; font-size: 1.05rem; }
    .nav { display: flex; align-items: center; gap: clamp(0.8rem, 2.5vw, 1.8rem); }
    .nav a {
      font-family: var(--font-mono); font-size: 0.78rem; letter-spacing: 0.08em;
      text-transform: uppercase; color: var(--ink-dim); transition: color .25s var(--ease-premium);
    }
    .nav a:hover { color: var(--accent-gold-light); }
    .nav-wa { color: #25d366 !important; }

    .nav-toggle {
      display: none;
      width: 44px; height: 44px; flex-shrink: 0;
      background: transparent; border: 1px solid var(--line-2); border-radius: 4px;
      flex-direction: column; align-items: center; justify-content: center; gap: 5px;
      cursor: pointer; transition: border-color .25s var(--ease-premium);
    }
    .nav-toggle:hover, .nav-toggle[aria-expanded="true"] { border-color: var(--accent-gold); }
    .nav-toggle-bar {
      display: block; width: 20px; height: 2px; background: var(--ink);
      transition: transform .3s var(--ease-premium), opacity .3s var(--ease-premium);
    }
    .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(2) { opacity: 0; }
    .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    .mobile-nav {
      display: none;
      flex-direction: column;
      background: var(--bg);
      border-top: 1px solid var(--line);
      padding: 0.4rem var(--pad) 1rem;
    }
    .mobile-nav a {
      display: block; padding: 0.95rem 0.15rem;
      font-family: var(--font-mono); font-size: 0.95rem; letter-spacing: 0.05em;
      text-transform: uppercase; color: var(--ink-dim);
      border-bottom: 1px solid var(--line);
      transition: color .2s var(--ease-premium);
    }
    .mobile-nav a:last-child { border-bottom: none; }
    .mobile-nav a:hover, .mobile-nav a:active { color: var(--accent-gold-light); }
    .mobile-nav-wa { color: #25d366 !important; }

    @media (max-width: 760px) {
      .nav { display: none; }
      .nav-toggle { display: flex; }
      .mobile-nav.is-open { display: flex; }
    }

    .site-footer {
      position: relative; margin-top: 2rem;
      background: linear-gradient(180deg, transparent, var(--bg-2) 70px);
    }
    .site-footer::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
      background: linear-gradient(90deg, transparent, var(--line-2) 20%, var(--line-2) 80%, transparent);
    }
    .footer-grid {
      display: grid; grid-template-columns: 1.3fr 0.9fr 1fr 1fr; gap: 2.5rem;
      padding-block: 3.5rem 2rem;
    }
    .foot-name { font-family: var(--font-display); text-transform: uppercase; font-size: 1.2rem; margin-top: 0.9rem; }
    .foot-h {
      font-size: 0.8rem; letter-spacing: 0.16em; color: var(--ink);
      margin-bottom: 0.9rem; padding-bottom: 0.6rem;
      border-bottom: 1px solid rgba(var(--gold-rgb), .22);
    }
    .foot-nav { display: flex; flex-direction: column; gap: 0.7rem; }
    .foot-nav a { color: var(--ink-dim); font-size: 0.9rem; transition: color .25s var(--ease-premium); }
    .foot-nav a:hover { color: var(--accent-gold-light); }
    .foot-dim { color: var(--ink-dim); font-size: 0.9rem; line-height: 1.9; }
    .foot-dim a { transition: color .25s var(--ease-premium); }
    .foot-dim a:hover { color: var(--accent-gold-light); }
    .foot-gst { font-family: var(--font-mono); font-size: 0.72rem; color: var(--ink-faint); margin-top: 0.8rem; letter-spacing: 0.05em; }
    .foot-bottom {
      border-top: 1px solid var(--line); padding-block: 1.3rem;
      font-family: var(--font-mono); font-size: 0.72rem; color: var(--ink-faint); letter-spacing: 0.04em;
    }
    @media (max-width: 860px) { .footer-grid { grid-template-columns: 1fr 1fr; gap: 2rem; } }
    @media (max-width: 480px) { .footer-grid { grid-template-columns: 1fr; } }

    .wa-float {
      position: fixed; right: 1.1rem; bottom: 1.1rem; z-index: 60;
      width: 54px; height: 54px; border-radius: 50%;
      background: #25d366; color: #062b14;
      display: grid; place-items: center;
      box-shadow: 0 6px 20px rgba(0,0,0,.4);
      transition: transform .3s var(--ease-premium), box-shadow .3s var(--ease-premium);
    }
    .wa-float:hover { transform: scale(1.08); box-shadow: 0 10px 28px rgba(0,0,0,.5); }
  </style>
</body>
</html>
