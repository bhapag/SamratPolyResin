---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import { site } from '../data/site.js';

const { title, description } = Astro.props;
const pageTitle = title ? `${title} — ${site.name}` : `${site.name} — ${site.tagline}`;
const desc = description ?? `${site.name}: manufacturer of coating and composite resins from ${site.address.line2}, ${site.address.state}. Established ${site.established}.`;
const waLink = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent("Hi, I'd like to enquire about your resins.")}`;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{pageTitle}</title>
  <meta name="description" content={desc} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={desc} />
  <meta property="og:type" content="website" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <ClientRouter />
</head>
<body>
  <header class="site-header" transition:persist>
    <div class="wrap header-inner">
      <a href="/" class="brand">
        <img src="/logo.jpg" alt={`${site.name} logo`} class="brand-mark" width="40" height="40" />
        <span class="brand-name">{site.name}</span>
      </a>
      <nav class="nav" aria-label="Primary">
        <a href="/">Home</a>
        <a href="/products/">Products</a>
        <a href="/about/">About</a>
        <a href="/contact/">Contact</a>
        <a href={waLink} class="nav-wa" target="_blank" rel="noopener">WhatsApp</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="wrap footer-grid">
      <div>
        <img src="/logo.jpg" alt={`${site.name} logo`} class="brand-mark big" width="64" height="64" />
        <p class="foot-name">{site.name}</p>
        <p class="foot-dim">Manufacturer of coating &amp; composite resins.<br/>Established {site.established}.</p>
      </div>
      <div>
        <h4 class="foot-h">Reach us</h4>
        <p class="foot-dim">
          {site.proprietor} (Proprietor)<br/>
          {site.address.line1}<br/>
          {site.address.line2} — {site.address.pin}<br/>
          {site.address.state}
        </p>
      </div>
      <div>
        <h4 class="foot-h">Contact</h4>
        <p class="foot-dim">
          <a href={`tel:${site.phoneDial}`}>{site.phoneDisplay}</a><br/>
          <a href={`mailto:${site.email}`}>{site.email}</a><br/>
          <a href={waLink} target="_blank" rel="noopener">WhatsApp enquiry</a>
        </p>
        <p class="foot-gst">GST {site.gst}</p>
      </div>
    </div>
    <div class="wrap foot-bottom">
      <span>© {new Date().getFullYear()} {site.name}. All rights reserved.</span>
    </div>
  </footer>

  <!-- floating whatsapp -->
  <a href={waLink} class="wa-float" target="_blank" rel="noopener" aria-label="Chat on WhatsApp" transition:persist>
    <svg viewBox="0 0 24 24" width="26" height="26" fill="currentColor" aria-hidden="true"><path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.2s-.8.9-.9 1.1c-.2.2-.3.2-.6.1-.3-.2-1.2-.5-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5 0-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.5c-.2 0-.5 0-.7.3-.2.3-.9.9-.9 2.2s1 2.5 1.1 2.7c.1.2 1.9 3 4.7 4.2.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.5-.1 1.7-.7 1.9-1.4.2-.6.2-1.2.2-1.4-.1-.1-.3-.2-.6-.3zM12 2a10 10 0 0 0-8.6 15l-1.3 4.7L7 20.4A10 10 0 1 0 12 2zm0 18.2c-1.5 0-3-.4-4.3-1.2l-.3-.2-3.1.8.8-3-.2-.3A8.2 8.2 0 1 1 12 20.2z"/></svg>
  </a>

  <style>
    .site-header {
      position: sticky; top: 0; z-index: 50;
      background: color-mix(in srgb, var(--bg) 88%, transparent);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--line);
    }
    .header-inner { display: flex; align-items: center; justify-content: space-between; height: 68px; }
    .brand { display: flex; align-items: center; gap: 0.7rem; }
    .brand-mark { width: 40px; height: 40px; border-radius: 50%; object-fit: cover; flex-shrink: 0; }
    .brand-mark.big { width: 64px; height: 64px; display: block; }
    .brand-name { font-family: var(--font-display); font-weight: 600; text-transform: uppercase; letter-spacing: 0.03em; font-size: 1.05rem; }
    .nav { display: flex; align-items: center; gap: clamp(0.8rem, 2.5vw, 1.8rem); }
    .nav a {
      font-family: var(--font-mono); font-size: 0.78rem; letter-spacing: 0.08em;
      text-transform: uppercase; color: var(--ink-dim); transition: color .18s;
    }
    .nav a:hover { color: var(--amber-2); }
    .nav-wa { color: #25d366 !important; }
    @media (max-width: 620px) {
      .brand-name { display: none; }
      .nav a:not(.nav-wa):nth-child(3) { display: none; }
    }

    .site-footer { border-top: 1px solid var(--line); background: var(--bg-2); margin-top: 2rem; }
    .footer-grid {
      display: grid; grid-template-columns: 1.4fr 1fr 1fr; gap: 2.5rem;
      padding-block: 3.5rem 2rem;
    }
    .foot-name { font-family: var(--font-display); text-transform: uppercase; font-size: 1.2rem; margin-top: 0.9rem; }
    .foot-h { font-size: 0.8rem; letter-spacing: 0.16em; color: var(--ink); margin-bottom: 0.8rem; }
    .foot-dim { color: var(--ink-dim); font-size: 0.9rem; line-height: 1.9; }
    .foot-dim a:hover { color: var(--amber-2); }
    .foot-gst { font-family: var(--font-mono); font-size: 0.72rem; color: var(--ink-faint); margin-top: 0.8rem; letter-spacing: 0.05em; }
    .foot-bottom {
      border-top: 1px solid var(--line); padding-block: 1.3rem;
      font-family: var(--font-mono); font-size: 0.72rem; color: var(--ink-faint); letter-spacing: 0.04em;
    }
    @media (max-width: 720px) { .footer-grid { grid-template-columns: 1fr; gap: 2rem; } }

    .wa-float {
      position: fixed; right: 1.1rem; bottom: 1.1rem; z-index: 60;
      width: 54px; height: 54px; border-radius: 50%;
      background: #25d366; color: #062b14;
      display: grid; place-items: center;
      box-shadow: 0 6px 20px rgba(0,0,0,.4);
      transition: transform .18s;
    }
    .wa-float:hover { transform: scale(1.08); }
  </style>
</body>
</html>
