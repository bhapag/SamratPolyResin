---
// Elegant placeholder for future real photography (never stock images).
const { label } = Astro.props;
---
<div class="image-placeholder">
  <span class="image-placeholder-icon" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="5" width="18" height="14" rx="1.5" />
      <circle cx="8.5" cy="10" r="1.6" />
      <path d="M3 16 L8 12 L12 15 L16 11 L21 16" />
    </svg>
  </span>
  <p class="image-placeholder-label">{label}</p>
</div>

<style>
  .image-placeholder {
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.7rem;
    aspect-ratio: 16 / 9; border: 1px dashed var(--line-2); background: var(--bg-3);
    margin-block: 1.6rem;
  }
  .image-placeholder-icon { color: var(--line-2); }
  .image-placeholder-label {
    font-family: var(--font-mono); font-size: 0.76rem; letter-spacing: 0.04em;
    text-transform: uppercase; color: var(--ink-faint); text-align: center; padding-inline: 1rem;
  }
</style>
