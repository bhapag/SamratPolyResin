---
const { product } = Astro.props;
const { slug, name, price, image, tagline, category } = product;
---
<a href={`/products/${slug}/`} class="card">
  <div class="card-img">
    <img src={`/products/${image}`} alt={name} loading="lazy" width="400" height="300"
         onerror="this.parentElement.classList.add('noimg'); this.remove();" />
    <span class="img-fallback" aria-hidden="true">{name.split(' ').map(w=>w[0]).join('').slice(0,3)}</span>
  </div>
  <div class="card-body">
    <span class="card-cat">{category}</span>
    <h3 class="card-name">{name}</h3>
    <p class="card-tag">{tagline}</p>
    <div class="card-foot">
      <span class="card-price">{price || 'Ask for price'}</span>
      <span class="card-arrow" aria-hidden="true">→</span>
    </div>
  </div>
</a>

<style>
  .card {
    display: flex; flex-direction: column;
    background: var(--bg-3);
    border: 1px solid var(--line);
    transition: border-color .2s, transform .2s;
    height: 100%;
  }
  .card:hover { border-color: var(--amber); transform: translateY(-3px); }
  .card:hover .card-arrow { transform: translateX(4px); color: var(--amber); }

  .card-img {
    position: relative; aspect-ratio: 4 / 3; overflow: hidden;
    background: linear-gradient(135deg, #1a1e24, #23282f);
    display: grid; place-items: center;
  }
  .card-img img { width: 100%; height: 100%; object-fit: cover; }
  .img-fallback {
    display: none;
    position: absolute; font-family: var(--font-display); font-weight: 700;
    font-size: 2.4rem; color: var(--line-2); letter-spacing: 0.05em;
  }
  .card-img.noimg { border-bottom: 1px solid var(--line); }
  .card-img.noimg .img-fallback { display: block; }

  .card-body { padding: 1.15rem 1.25rem 1.25rem; display: flex; flex-direction: column; flex: 1; }
  .card-cat {
    font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--ink-faint);
  }
  .card-name {
    font-size: 1.15rem; margin-top: 0.5rem; color: var(--ink);
    text-transform: none; letter-spacing: 0; font-weight: 600;
  }
  .card-tag { color: var(--ink-dim); font-size: 0.86rem; margin-top: 0.4rem; flex: 1; }
  .card-foot {
    display: flex; align-items: center; justify-content: space-between;
    margin-top: 1rem; padding-top: 0.9rem; border-top: 1px solid var(--line);
  }
  .card-price { font-family: var(--font-mono); font-size: 0.9rem; color: var(--amber-2); font-weight: 500; }
  .card-arrow { font-size: 1.1rem; color: var(--ink-dim); transition: transform .2s, color .2s; }
</style>
