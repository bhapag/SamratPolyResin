---
import { Image } from 'astro:assets';
import { site } from '../data/site.js';

const productImageModules = import.meta.glob('/src/assets/products/*', { eager: true });
const resolveProductImage = (filename) => productImageModules[`/src/assets/products/${filename}`]?.default;

const { product } = Astro.props;
const { slug, name, image, tagline, category } = product;
const img = resolveProductImage(image);
---
<a href={`/products/${slug}/`} class="card" data-product-card data-category={category} data-search={`${name} ${tagline}`.toLowerCase()}>
  <div class:list={['card-img', { noimg: !img }]}>
    {img && (
      <Image src={img} alt={name} loading="lazy" widths={[320, 480, 640]} sizes="(max-width: 640px) 100vw, 320px"
             transition:name={`product-photo-${slug}`} />
    )}
    <span class="img-fallback" aria-hidden="true">{name.split(' ').map(w=>w[0]).join('').slice(0,3)}</span>
  </div>
  <div class="card-body">
    <span class="card-cat">{category}</span>
    <h3 class="card-name" transition:name={`product-name-${slug}`}>{name}</h3>
    <p class="card-tag">{tagline}</p>
    <div class="card-foot">
      <span class="card-price">{site.priceLabel}</span>
      <span class="card-arrow" aria-hidden="true">→</span>
    </div>
  </div>
</a>

<style>
  .card {
    display: flex; flex-direction: column;
    background: var(--bg-3);
    border: 1px solid var(--line);
    box-shadow: var(--surface-shadow-rest);
    transition: border-color .3s var(--ease-premium), transform .3s var(--ease-premium), box-shadow .3s var(--ease-premium);
    height: 100%;
  }
  .card:hover {
    border-color: var(--accent-gold); transform: translateY(-4px) scale(1.012);
    box-shadow: var(--surface-shadow-hover);
  }
  .card:hover .card-arrow { transform: translateX(4px); color: var(--accent-gold); }

  .card-img {
    position: relative; aspect-ratio: 1 / 1; overflow: hidden;
    background: linear-gradient(135deg, #1a1e24, #23282f);
    display: grid; place-items: center;
  }
  /* contain, not cover — these are complete marketing posters (text, logo,
     spec tables baked into the artwork), not cropped-to-fill photography;
     the whole poster must stay visible, so no zoom-on-hover here either.
     position:absolute + inset:0 (not width/height:100%) because percentage
     heights don't reliably resolve against an aspect-ratio-derived height
     inside a `place-items:center` grid in every browser — absolute
     positioning against the relative parent sizes unambiguously instead. */
  .card-img img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: contain; }
  .img-fallback {
    display: none;
    position: absolute; font-family: var(--font-display); font-weight: 700;
    font-size: 2.4rem; color: var(--line-2); letter-spacing: 0.05em;
  }
  .card-img.noimg { border-bottom: 1px solid var(--line); }
  .card-img.noimg .img-fallback { display: block; }

  .card-body { padding: 1.15rem 1.25rem 1.25rem; display: flex; flex-direction: column; flex: 1; }
  .card-cat {
    font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--ink-faint);
  }
  .card-name {
    font-size: 1.15rem; margin-top: 0.5rem; color: var(--ink);
    text-transform: none; letter-spacing: 0; font-weight: 600;
  }
  .card-tag { color: var(--ink-dim); font-size: 0.86rem; margin-top: 0.4rem; flex: 1; }
  .card-foot {
    display: flex; align-items: center; justify-content: space-between;
    margin-top: 1rem; padding-top: 0.9rem; border-top: 1px solid var(--line);
  }
  .card-price { font-family: var(--font-mono); font-size: 0.9rem; color: var(--accent-gold-light); font-weight: 500; }
  .card-arrow { font-size: 1.1rem; color: var(--ink-dim); transition: transform .3s var(--ease-premium), color .3s var(--ease-premium); }
</style>
