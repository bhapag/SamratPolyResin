---
import ResourceIcon from './ResourceIcon.astro';
const { resource } = Astro.props;
const { slug, title, description, readingTime, icon } = resource;
---
<a href={`/resources/${slug}/`} class="res-card">
  <span class="res-card-icon" aria-hidden="true"><ResourceIcon name={icon} /></span>
  <h3 class="res-card-title">{title}</h3>
  <p class="res-card-desc">{description}</p>
  <div class="res-card-foot">
    <span class="res-card-time">{readingTime}</span>
    <span class="res-card-link">Read Article →</span>
  </div>
</a>

<style>
  .res-card {
    display: flex; flex-direction: column; gap: 0.9rem; height: 100%;
    background: var(--bg-3); border: 1px solid var(--line);
    padding: 1.5rem 1.5rem 1.4rem;
    transition: border-color .3s var(--ease-premium), transform .3s var(--ease-premium), box-shadow .3s var(--ease-premium);
  }
  .res-card:hover {
    border-color: var(--amber); transform: translateY(-4px) scale(1.012);
    box-shadow: 0 14px 32px rgba(0, 0, 0, .3);
  }
  .res-card:hover .res-card-link { transform: translateX(3px); color: var(--amber); }

  .res-card-icon {
    display: flex; align-items: center; justify-content: center;
    width: 44px; height: 44px; color: var(--amber);
  }
  .res-card-icon :global(svg) { width: 26px; height: 26px; }

  .res-card-title { font-size: 1.05rem; color: var(--ink); text-transform: none; letter-spacing: 0; font-weight: 600; }
  .res-card-desc { color: var(--ink-dim); font-size: 0.88rem; flex: 1; }

  .res-card-foot {
    display: flex; align-items: center; justify-content: space-between;
    margin-top: 0.6rem; padding-top: 0.9rem; border-top: 1px solid var(--line);
  }
  .res-card-time { font-family: var(--font-mono); font-size: 0.72rem; color: var(--ink-faint); letter-spacing: 0.04em; }
  .res-card-link { font-family: var(--font-mono); font-size: 0.78rem; color: var(--amber-2); font-weight: 500; transition: transform .3s var(--ease-premium), color .3s var(--ease-premium); }
</style>
