---
const { faqs } = Astro.props;
---
<div class="faq-accordion">
  {faqs.map((item, i) => (
    <div class="faq-item">
      <h3>
        <button type="button" class="faq-question" aria-expanded="false" aria-controls={`faq-panel-${i}`} id={`faq-question-${i}`}>
          <span>{item.q}</span>
          <span class="faq-chevron" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6" /></svg>
          </span>
        </button>
      </h3>
      <div class="faq-panel" id={`faq-panel-${i}`} role="region" aria-labelledby={`faq-question-${i}`}>
        <div class="faq-panel-inner"><p>{item.a}</p></div>
      </div>
    </div>
  ))}
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll<HTMLElement>('.faq-accordion').forEach((group) => {
      if (group.dataset.wired === 'true') return;
      group.dataset.wired = 'true';

      const questions = Array.from(group.querySelectorAll<HTMLButtonElement>('.faq-question'));

      const closeItem = (btn: HTMLButtonElement) => {
        btn.setAttribute('aria-expanded', 'false');
        const item = btn.closest('.faq-item');
        const panel = item?.querySelector<HTMLElement>('.faq-panel');
        item?.classList.remove('is-open');
        if (panel) panel.style.maxHeight = '';
      };

      const openItem = (btn: HTMLButtonElement) => {
        btn.setAttribute('aria-expanded', 'true');
        const item = btn.closest('.faq-item');
        const panel = item?.querySelector<HTMLElement>('.faq-panel');
        const inner = panel?.querySelector<HTMLElement>('.faq-panel-inner');
        item?.classList.add('is-open');
        if (panel && inner) panel.style.maxHeight = inner.scrollHeight + 'px';
      };

      questions.forEach((btn) => {
        btn.addEventListener('click', () => {
          const wasOpen = btn.getAttribute('aria-expanded') === 'true';
          questions.forEach(closeItem);
          if (!wasOpen) openItem(btn);
        });
      });
    });
  });
</script>

<style>
  .faq-accordion { display: flex; flex-direction: column; gap: 0.9rem; }
  .faq-item { background: var(--bg-3); border: 1px solid var(--line); transition: border-color .3s var(--ease-premium); }
  .faq-item.is-open { border-color: var(--amber-deep); }
  .faq-item h3 { text-transform: none; letter-spacing: 0; font-weight: 400; }

  .faq-question {
    width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    padding: 1.1rem 1.3rem; background: none; border: none; cursor: pointer;
    font-family: var(--font-body); font-size: 1rem; font-weight: 600; color: var(--ink); text-align: left;
    transition: color .25s var(--ease-premium);
  }
  .faq-question:hover { color: var(--amber-2); }
  .faq-question span:first-child { flex: 1; }
  .faq-chevron {
    display: flex; color: var(--ink-faint); flex-shrink: 0;
    transition: transform .3s var(--ease-premium), color .3s var(--ease-premium);
  }
  .faq-question:hover .faq-chevron { color: var(--amber-2); }
  .faq-item.is-open .faq-chevron { transform: rotate(180deg); color: var(--amber); }

  .faq-panel { max-height: 0; overflow: hidden; transition: max-height .35s var(--ease-premium); }
  .faq-panel-inner p { color: var(--ink-dim); font-size: 0.94rem; padding: 0 1.3rem 1.2rem; }
</style>
