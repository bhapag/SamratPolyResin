---
// Technical-documentation callout box.
// variant: info | technical | practice | warning | takeaway (default: info)
const { label, variant = 'info' } = Astro.props;
const c = {
  viewBox: "0 0 24 24", width: "16", height: "16", fill: "none",
  stroke: "currentColor", "stroke-width": "1.8", "stroke-linecap": "round", "stroke-linejoin": "round",
};
---
<div class={`callout callout-${variant}`}>
  <div class="callout-head">
    <span class="callout-icon" aria-hidden="true">
      {variant === 'info' && (
        <svg {...c}><circle cx="12" cy="12" r="9" /><line x1="12" y1="11" x2="12" y2="16" /><circle cx="12" cy="7.5" r="0.9" fill="currentColor" stroke="none" /></svg>
      )}
      {variant === 'technical' && (
        <svg {...c}><rect x="4" y="3" width="16" height="18" rx="1.5" /><line x1="8" y1="8" x2="16" y2="8" /><line x1="8" y1="12" x2="16" y2="12" /><line x1="8" y1="16" x2="13" y2="16" /></svg>
      )}
      {variant === 'practice' && (
        <svg {...c}><path d="M12 2 L20 5 L20 11 C20 16 16.5 20 12 22 C7.5 20 4 16 4 11 L4 5 Z" /><path d="M9 12 l2 2 l4 -4" /></svg>
      )}
      {variant === 'warning' && (
        <svg {...c}><path d="M12 3 L22 20 L2 20 Z" /><line x1="12" y1="9" x2="12" y2="14" /><circle cx="12" cy="17" r="0.9" fill="currentColor" stroke="none" /></svg>
      )}
      {variant === 'takeaway' && (
        <svg {...c}><path d="M12 2 L14.5 8.5 L21.5 9 L16.3 13.3 L18 20 L12 16.3 L6 20 L7.7 13.3 L2.5 9 L9.5 8.5 Z" /></svg>
      )}
    </span>
    <p class="callout-label">{label}</p>
  </div>
  <div class="callout-body"><slot /></div>
</div>

<style>
  .callout {
    background: var(--bg-3); border: 1px solid var(--line); border-left: 3px solid var(--accent-gold);
    padding: 1.1rem 1.3rem; margin-block: 1.6rem;
  }
  .callout-warning { border-left-color: #ff6b6b; }
  .callout-takeaway { background: color-mix(in srgb, var(--accent-gold) 6%, var(--bg-3)); }

  .callout-head { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.6rem; }
  .callout-icon { display: flex; color: var(--accent-gold); flex-shrink: 0; }
  .callout-warning .callout-icon { color: #ff8f8f; }
  .callout-label {
    font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--accent-gold-light);
  }
  .callout-warning .callout-label { color: #ff8f8f; }

  .callout-body { color: var(--ink-dim); font-size: 0.92rem; }
  .callout-body :global(ul) { list-style: none; display: flex; flex-direction: column; gap: 0.7rem; margin-top: 0.3rem; }
  .callout-body :global(li) {
    position: relative; padding-left: 1.6rem; color: var(--ink); font-weight: 600;
    line-height: 1.6; text-shadow: 0 1px 3px rgba(0, 0, 0, .22);
    transition: color .25s var(--ease-premium), transform .25s var(--ease-premium);
  }
  .callout-body :global(li):hover { color: #ffffff; transform: translateX(3px); }
  .callout-body :global(li)::before {
    content: '✓'; position: absolute; left: 0; top: 50%; transform: translateY(-50%);
    display: flex; align-items: center; justify-content: center;
    width: 16px; height: 16px; border-radius: 50%;
    background: linear-gradient(180deg, var(--accent-gold-light), var(--accent-gold-dark));
    color: #17120c; font-size: 0.56rem; font-weight: 700; line-height: 1;
    box-shadow: 0 0 0 1px rgba(var(--gold-rgb), .3), 0 1px 4px rgba(0, 0, 0, .3);
    transition: box-shadow .25s var(--ease-premium), transform .25s var(--ease-premium);
  }
  .callout-body :global(li):hover::before {
    box-shadow: 0 0 10px rgba(var(--gold-rgb), .5), 0 0 0 1px rgba(var(--gold-rgb), .45);
    transform: translateY(-50%) scale(1.08);
  }
  .callout-warning .callout-body :global(li)::before { background: linear-gradient(180deg, #ffb3b3, #d94848); }
  .callout-body :global(p) { margin: 0; }
</style>
