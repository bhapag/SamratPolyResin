---
// Clean stroke-based line icons for the manufacturing-methods and
// applications grids, matching the same style used across ResourceIcon.astro
// and the homepage's "Industries We Serve" icons.
const { name } = Astro.props;
const c = {
  viewBox: "0 0 24 24",
  fill: "none",
  stroke: "currentColor",
  "stroke-width": "1.6",
  "stroke-linecap": "round",
  "stroke-linejoin": "round",
};
---
{name === 'hand-layup' && (
  <svg {...c}><rect x="9" y="2.5" width="6" height="9" rx="1" /><line x1="12" y1="11.5" x2="12" y2="19" /><line x1="8.5" y1="20.5" x2="15.5" y2="20.5" /></svg>
)}
{name === 'spray-up' && (
  <svg {...c}><rect x="7" y="9" width="8" height="12" rx="1.2" /><path d="M9.5 9 L9.5 5 L13.5 5 L13.5 9" /><line x1="17" y1="7" x2="20.5" y2="5.5" /><line x1="17" y1="11" x2="21" y2="11" /><line x1="17" y1="15" x2="20.5" y2="16.5" /></svg>
)}
{name === 'compression' && (
  <svg {...c}><line x1="4" y1="5.5" x2="20" y2="5.5" /><line x1="4" y1="18.5" x2="20" y2="18.5" /><path d="M12 8 L12 10.5" /><path d="M12 10.5 L9.5 8.5 M12 10.5 L14.5 8.5" /><path d="M12 16 L12 13.5" /><path d="M12 13.5 L9.5 15.5 M12 13.5 L14.5 15.5" /></svg>
)}
{name === 'pultrusion' && (
  <svg {...c}><rect x="9.5" y="8.5" width="5" height="7" /><line x1="2" y1="12" x2="9.5" y2="12" /><line x1="14.5" y1="12" x2="21" y2="12" /><path d="M18 9.5 L21.5 12 L18 14.5" /></svg>
)}
{name === 'lamination' && (
  <svg {...c}><circle cx="3.5" cy="12" r="1.8" /><circle cx="20.5" cy="12" r="1.8" /><line x1="5.3" y1="8.5" x2="18.7" y2="8.5" /><line x1="5.3" y1="12" x2="18.7" y2="12" /><line x1="5.3" y1="15.5" x2="18.7" y2="15.5" /></svg>
)}
{name === 'vacuum' && (
  <svg {...c}><path d="M4 11 Q12 3 20 11 L20 20 L4 20 Z" /><line x1="9" y1="14" x2="9" y2="17.5" /><line x1="15" y1="14" x2="15" y2="17.5" /><path d="M7.5 15.5 L9 17.5 L10.5 15.5" /><path d="M13.5 15.5 L15 17.5 L16.5 15.5" /></svg>
)}
{name === 'tank' && (
  <svg {...c}><ellipse cx="12" cy="5" rx="7" ry="2.5" /><path d="M5 5 L5 19 A7 2.5 0 0 0 19 19 L19 5" /></svg>
)}
{name === 'roof' && (
  <svg {...c}><path d="M2 9 L7 5 L12 9 L17 5 L22 9" /><path d="M2 14 L7 10 L12 14 L17 10 L22 14" /></svg>
)}
{name === 'door' && (
  <svg {...c}><rect x="5" y="2" width="14" height="20" rx="1" /><circle cx="15.3" cy="12" r="0.9" fill="currentColor" stroke="none" /></svg>
)}
{name === 'marine' && (
  <svg {...c}><circle cx="12" cy="5" r="2" /><line x1="12" y1="7" x2="12" y2="19" /><path d="M6 12 L6 15 A6 6 0 0 0 18 15 L18 12" /><line x1="8" y1="10" x2="16" y2="10" /></svg>
)}
{name === 'moulding' && (
  <svg {...c}><circle cx="12" cy="12" r="4" /><line x1="12" y1="2.5" x2="12" y2="5.5" /><line x1="12" y1="18.5" x2="12" y2="21.5" /><line x1="2.5" y1="12" x2="5.5" y2="12" /><line x1="18.5" y1="12" x2="21.5" y2="12" /><line x1="5.4" y1="5.4" x2="7.5" y2="7.5" /><line x1="16.5" y1="16.5" x2="18.6" y2="18.6" /><line x1="5.4" y1="18.6" x2="7.5" y2="16.5" /><line x1="16.5" y1="7.5" x2="18.6" y2="5.4" /></svg>
)}
{name === 'decorative' && (
  <svg {...c}><rect x="4" y="4" width="16" height="16" rx="1.5" /><line x1="4" y1="12" x2="20" y2="12" /></svg>
)}
{name === 'construction' && (
  <svg {...c}><path d="M5 21 L5 9 L12 3 L19 9 L19 21" /><line x1="9" y1="13" x2="9" y2="16" /><line x1="15" y1="13" x2="15" y2="16" /></svg>
)}
{name === 'automotive' && (
  <svg {...c}><path d="M4 16 L5 11 Q6 9 8 9 L16 9 Q18 9 19 11 L20 16" /><rect x="3" y="16" width="18" height="3" rx="1" /><circle cx="7.5" cy="19.3" r="1.5" /><circle cx="16.5" cy="19.3" r="1.5" /></svg>
)}
